# Copy this file to .env and fill in your own local settings.

APP_PYTHON_EXE=

BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=8766
BACKEND_BASE_URL=http://127.0.0.1:8766
BACKEND_TIMEOUT_SECONDS=30

SCRAPER_LOCALE=zh-CN
SCRAPER_BROWSER_CHANNEL=chrome
BROWSER_PROFILES_DIR=browser_profiles
AVFAN_PROFILE_DIR=browser_profiles/avfan

SCRAPER_HOME_URL=https://example.com/zh-CN
SCRAPER_LOGIN_URL=https://example.com/zh-CN/sign_in
SCRAPER_USERNAME=your_login_email@example.com
SCRAPER_PASSWORD=your_password_here

AVFAN_BASE_URL=https://example.com
AVFAN_ACTOR_SEARCH_URL_TEMPLATE={base_url}/search?q={query}&st=cast
AVFAN_CODE_PREFIX_URL_TEMPLATE={base_url}/zh-CN/number_letters/{prefix}?page={page}

JAVTXT_BASE_URL=https://example.org
JAVTXT_SEARCH_URL_TEMPLATE={base_url}/search?type=id&q={code}

PROBE_TARGET_URL=
PROBE_SHOW_BROWSER=true
PROBE_MAX_LINES=820
PROBE_MAX_ENTRIES=90
